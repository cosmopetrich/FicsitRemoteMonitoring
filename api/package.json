{
  "devDependencies": {
    "@hey-api/client-fetch": "^0.4.2",
    "@hey-api/openapi-ts": "^0.53.11",
    "@redocly/cli": "^1.25.8",
    "@types/node": "^22.7.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "openapi-bundle": "tsx ./scripts/openapi-set-version.ts dist/frm-openapi.json",
    "preopenapi-bundle": "redocly bundle -o dist/frm-openapi.json resources/openapi/frm-openapi.yaml",
    "openapi-clients": "npm run openapi-client-ts",
    "openapi-client-ts": "openapi-ts -i dist/frm-openapi.json -o dist/clients/typescript -c @hey-api/client-fetch",
    "preopenapi-client-ts": "npm run openapi-bundle",
    "openapi-docs": "redocly build-docs -o dist/redoc-static.html dist/frm-openapi.json",
    "preopenapi-docs": "npm run openapi-bundle",
    "openapi-lint": "spectral lint resources/openapi/frm-openapi.yaml",
    "openapi-yaml-check": "yq resources/openapi/*.yaml resources/openapi/**/*.yaml",
    "tests": "tsx ./tests/contract.ts",
    "pretest": "npm run openapi-client-ts"
  }
}
