{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.9.0",
    "generators": {
      "python": {
        "generatorName": "python",
        "version": "0.0.0-fixme",
        "glob": "openapi.yaml",
        "output": "#{cwd}/clients/python/",
        "additionalProperties": {
          "packageName": "ficsit_remote_monitoring_client"
        }
      }
    }
  }
}
